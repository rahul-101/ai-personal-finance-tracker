# Copy this file to backend/.env and fill in your own values. Never commit backend/.env.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
DATABASE_NAME=finance_tracker

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
# Local development only. Set this to 0 for HTTPS deployments.
OAUTHLIB_INSECURE_TRANSPORT=1

# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# AI provider configuration. AI_PROVIDER supports: gemini, openai, anthropic, ollama.
# AI_API_KEY is preferred; provider-specific keys remain supported for compatibility.
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_API_KEY=
# Optional: use for compatible gateways or a local Ollama URL.
AI_BASE_URL=

# Legacy Gemini settings remain supported while migrating to AI_* variables.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Copy this file to backend/.env and fill in your own values. Never commit backend/.env.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
DATABASE_NAME=finance_tracker

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
# Local development only. Set this to 0 for HTTPS deployments.
OAUTHLIB_INSECURE_TRANSPORT=1

# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# AI provider configuration. Select one provider:
# gemini, openai, anthropic, groq, mistral, deepseek, xai, or together.
# AI_API_KEY is preferred. Alternatively, use the matching provider-specific key below.
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_API_KEY=
# Optional: override a compatible provider's default API base URL.
AI_BASE_URL=

# Provider-specific key alternatives. Use only one key for the selected provider.
# Gemini example:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI example:
OPENAI_API_KEY=

# Anthropic example:
ANTHROPIC_API_KEY=

# OpenAI-compatible provider examples (also set AI_MODEL to the model you choose):
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
